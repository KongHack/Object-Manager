{
  "name": "gcworld/objectmanager",
  "description": "GCWorld Industries Object Manager",
  "authors": [
    {
      "name": "GameCharmer",
      "email": "admin@gamecharmer.com"
    }
  ],
  "require": {
    "php": ">=8.4",
    "composer/composer": ">=2.7",
    "gcworld/utilities": ">=2.0",
    "symfony/yaml": "^6.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {"GCWorld\\ObjectManager\\": "src/"}
  },
  "autoload-dev": {
    "psr-4": {"GCWorld\\ObjectManager\\Tests\\": "tests/"}
  },
  "bin": [
    "bin/migrate-docblocks.php"
  ],
  "scripts": {
    "post-autoload-dump": [
      "GCWorld\\ObjectManager\\ComposerInstaller::setupConfig"
    ],
    "test": "phpunit",
    "migrate-docblocks": "php bin/migrate-docblocks.php"
  },
  "license":"MIT"
}
